{
  "name": "corpus",
  "version": "0.1.0",
  "private": true,
  "description": "LUDIARS Corpus — hub service aggregating LUDIARS services (Cernere SSO + plugin packs)",
  "type": "module",
  "scripts": {
    "predev": "npm run build:web",
    "dev": "tsx watch --env-file-if-exists=.env.secrets --env-file-if-exists=.env server/bootstrap.ts",
    "dev:debug": "tsx watch --env-file-if-exists=.env.secrets --env-file-if-exists=.env server/bootstrap.ts --no-cernere --port=5187",
    "prestart": "npm run build:web",
    "start": "tsx --env-file-if-exists=.env.secrets --env-file-if-exists=.env server/bootstrap.ts",
    "vendor:css": "node scripts/copy-vendor-css.mjs",
    "build:web": "npm run vendor:css && esbuild public/src/app.ts --bundle --outfile=public/app.js --target=es2020 --sourcemap --format=esm",
    "watch:web": "npm run vendor:css && esbuild public/src/app.ts --bundle --outfile=public/app.js --target=es2020 --sourcemap --format=esm --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.frontend.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "launch": "tsx scripts/launch.ts",
    "launch:list": "tsx scripts/launch.ts --list"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.3.0",
    "dockview-core": "^6.6.0",
    "hono": "^4.6.10",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "esbuild": "^0.27.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.8"
  }
}
