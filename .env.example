# Corpus — アプリ設定。 運用では Infisical (env-cli) 推奨、 ローカルは .env 直書き可。

# --- 認証 (必須) ---
CERNERE_BASE_URL=http://localhost:8080
CORPUS_PUBLIC_URL=http://localhost:5185
CORPUS_ADMIN_IDS=

# --- listen / data ---
CORPUS_PORT=5185
CORPUS_DATA=./data

# --- frontend 配信元 (用途特化 hub が submodule から起動する時に指定) ---
# CORPUS_PUBLIC_DIR=./public

# --- プラグインパック (未設定なら本体のみで起動) ---
# CORPUS_PLUGIN_DIR=../VantanHub/plugins

# --- ローカルアプリがマルチ情報を取りに行くサーバサイドアプリ URL ---
# CORPUS_REMOTE_URL=https://corpus.example.com

# --- Infisical bootstrap (.env.secrets に置くのが通例) ---
# INFISICAL_SITE_URL=
# INFISICAL_PROJECT_ID=
# INFISICAL_ENVIRONMENT=dev
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
