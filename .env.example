# Corpus — アプリ設定。 運用では Infisical (env-cli) 推奨、 ローカルは .env 直書き可。

# --- 認証 (必須) ---
CERNERE_BASE_URL=http://localhost:8080
CORPUS_PUBLIC_URL=http://localhost:5185
CORPUS_ADMIN_IDS=
# external-id マッピングの issuer 識別子 (未設定なら CERNERE_BASE_URL を使う)
# CORPUS_CERNERE_ISSUER=

# --- listen / data ---
CORPUS_PORT=5185
CORPUS_DATA=./data

# --- frontend 配信元 (用途特化 hub が submodule から起動する時に指定) ---
# CORPUS_PUBLIC_DIR=./public

# --- プラグインパック (未設定なら本体のみで起動) ---
# CORPUS_PLUGIN_DIR=../VantanHub/plugins

# --- 自身のサービス識別 (別 Corpus から参照される時のマニフェスト用) ---
# CORPUS_SERVICE_ID=corpus
# CORPUS_DISPLAY_NAME=Corpus

# --- 動作モード (D1): local = ローカル probe / server = 設定 URL を参照 ---
CORPUS_MODE=server
# local モードで probe する loopback ポート (既定は LUDIARS PORT-MAP の主要
# サービス全部: Memoria 5180 / Actio 8888 / Concordia 17330 / Susurrus 17370 /
# Quaestor 17400 / Bibliotheca 17501 / Aedilis 17502 / Custos 17777)
# CORPUS_LOCAL_PROBE_PORTS=5180,8888,17330,17370,17400,17501,17502,17777
# server モードで参照する baseUrl (カンマ区切り)
# CORPUS_SERVER_SERVICES=https://actio.example.com,https://bibliotheca.example.com

# --- 認証トークン伝播 (D5): passthrough | cernere-project-token ---
# 明示必須 (無言フォールバック禁止)。 未設定だと起動を拒否する。
#   passthrough           : 受信 Bearer をそのまま転送 (audience が揃う構成 /
#                           無認証ローカル直結向け)。
#   cernere-project-token : 参照先プロジェクト用の短命 PASETO を発行 (本番想定)。
# 例外: ローカル無認証 dev (--no-cernere / CORPUS_NO_AUTH=1) のときだけ、
# 未設定でも passthrough を既定として許す。
CORPUS_TOKEN_MODE=passthrough

# --- ローカルアプリがマルチ情報を取りに行くサーバサイドアプリ URL ---
# CORPUS_REMOTE_URL=https://corpus.example.com

# --- Infisical bootstrap (.env.secrets に置くのが通例) ---
# INFISICAL_SITE_URL=
# INFISICAL_PROJECT_ID=
# INFISICAL_ENVIRONMENT=dev
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
